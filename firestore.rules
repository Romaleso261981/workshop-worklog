rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isManager() {
      return signedIn() && userDoc().role in ['ADMIN', 'OWNER'];
    }

    function isEmployee() {
      return signedIn() && userDoc().role == 'EMPLOYEE';
    }

    /** Працівник може лише перевести замовлення в архів (DONE + completedAt), без інших змін полів. */
    function orderWorkerArchiveOnly() {
      let diff = request.resource.data.diff(resource.data);
      return signedIn()
        && resource.data.status == 'IN_PRODUCTION'
        && request.resource.data.status == 'DONE'
        && diff.addedKeys().union(diff.changedKeys()).union(diff.removedKeys()).hasOnly(['status', 'completedAt']);
    }

    /** Працівник може рухати картку kanban лише між етапами з аудитом переміщення. */
    function orderWorkerBoardMoveOnly() {
      let diff = request.resource.data.diff(resource.data);
      let changed = diff.addedKeys().union(diff.changedKeys()).union(diff.removedKeys());
      let before = resource.data.stageMoveHistory == null ? [] : resource.data.stageMoveHistory;
      let after = request.resource.data.stageMoveHistory == null ? [] : request.resource.data.stageMoveHistory;
      let last = after[after.size() - 1];
      return isEmployee()
        && changed.hasOnly(['status', 'boardStage', 'completedAt', 'updatedAt', 'stageMoveHistory'])
        && request.resource.data.status == 'IN_PRODUCTION'
        && request.resource.data.completedAt == null
        && (
          request.resource.data.boardStage == null
          || request.resource.data.boardStage in ['PACK', 'CLEAN', 'PAINT', 'PREP']
        )
        && request.resource.data.updatedAt == request.time
        && before is list
        && after is list
        && after.size() == before.size() + 1
        && last is map
        && last.actorUserId == request.auth.uid
        && last.fromStage in ['NEW', 'PACK', 'CLEAN', 'PAINT', 'PREP']
        && (
          last.toStage == 'NEW'
          || last.toStage in ['PACK', 'CLEAN', 'PAINT', 'PREP']
        )
        && last.movedAt is timestamp;
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && (request.auth.uid == uid || isManager());
      allow delete: if false;
    }

    match /orders/{id} {
      allow read: if signedIn();
      allow create, delete: if isManager();
      allow update: if isManager() || orderWorkerArchiveOnly() || orderWorkerBoardMoveOnly();
    }

    match /orders/{orderId}/issuedMaterials/{issueId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && get(/databases/$(database)/documents/orders/$(orderId)).data.status == 'IN_PRODUCTION'
        && request.resource.data.materialId is string
        && request.resource.data.materialId.size() > 0
        && request.resource.data.materialId.size() <= 200
        && request.resource.data.materialName is string
        && request.resource.data.materialName.size() > 0
        && request.resource.data.materialName.size() <= 500
        && request.resource.data.materialCategory is string
        && request.resource.data.quantity is number
        && request.resource.data.quantity > 0
        && request.resource.data.quantity < 1000000
        && request.resource.data.addedByUid == request.auth.uid
        && (request.resource.data.addedByEmail == null
            || (request.resource.data.addedByEmail is string && request.resource.data.addedByEmail.size() <= 320))
        && request.resource.data.keys().hasAll(['materialId', 'materialName', 'materialCategory', 'quantity', 'addedByUid', 'createdAt'])
        && request.resource.data.createdAt == request.time;
      allow update, delete: if isManager();
    }

    match /workEntries/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /materials/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isManager();
    }

    match /employeeSalaryRates/{userId} {
      allow read: if isManager();
      allow create, update, delete: if isManager();
    }
  }
}
