# Firebase Web SDK (safe to expose with NEXT_PUBLIC — still keep out of public repos if possible)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Comma-separated emails → role on register / login sync (client-side)
NEXT_PUBLIC_WORKSHOP_ADMIN_EMAILS=
NEXT_PUBLIC_WORKSHOP_OWNER_EMAILS=
