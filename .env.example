# Firebase Web SDK (safe to expose with NEXT_PUBLIC — still keep out of public repos if possible)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Листи «підтвердження email» та «скидання пароля»: Firebase Console → Authentication → Templates
# (український текст можна змінити там). Authorized domains: додайте ваш домен і localhost для посилань з листів.

# Comma-separated emails → role on register / login sync (client-side)
NEXT_PUBLIC_WORKSHOP_ADMIN_EMAILS=
NEXT_PUBLIC_WORKSHOP_OWNER_EMAILS=

# Nova Poshta API — підказки населеного пункту та відділень у формі замовлення (як в інтернет-магазині).
# Як отримати ключ:
# 1) Увійдіть на https://novaposhta.ua/ (або кабінет для бізнесу) під своїм акаунтом Нової Пошти.
# 2) Меню користувача → «Інформаційні сервіси» / «API» (назва залежить від типу кабінету) або devcenter.novaposhta.ua
# 3) Створіть ключ API (інколи в «Налаштування» → «Безпека» → «API-ключ»).
# 4) Вставте ключ після знаку = (рядок не може бути порожнім після =). Лише сервер: без NEXT_PUBLIC_.
#    Перезапустіть dev-сервер після зміни.
# Документація методів: https://developers.novaposhta.ua/
NOVA_POSHTA_API_KEY=
